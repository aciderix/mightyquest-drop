    WinHttpOpen
    WinHttpOpenRequest
    WinHttpQueryAuthSchemes
    WinHttpQueryDataAvailable
    WinHttpQueryHeaders
    WinHttpQueryOption
    WinHttpReadData
    WinHttpReceiveResponse
    WinHttpSendRequest
    WinHttpSetCredentials
    WinHttpSetDefaultProxyConfiguration
    WinHttpSetOption
    WinHttpSetStatusCallback
    WinHttpSetTimeouts
    WinHttpTimeFromSystemTime
    WinHttpTimeToSystemTime
    WinHttpWriteData
